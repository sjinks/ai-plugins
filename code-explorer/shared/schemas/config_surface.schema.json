{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sjinks/ai-plugins/code-explorer/shared/schemas/config_surface.schema.json",
  "title": "config_surface.json",
  "type": "object",
  "required": ["_meta", "data"],
  "properties": {
    "_meta": { "$ref": "common.schema.json#/$defs/artifactMeta" },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "kind", "confidence"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/stableId" },
          "name": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["env", "file", "flag", "secret", "feature-flag", "runtime-option", "other"]
          },
          "required": { "type": "boolean" },
          "defaultValue": { "type": ["string", "number", "boolean", "null"] },
          "usedBy": { "type": "array", "items": { "type": "string" } },
          "validation": { "type": "string" },
          "risk": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "confidence": { "$ref": "common.schema.json#/$defs/confidence" },
          "status": { "$ref": "common.schema.json#/$defs/status" }
        }
      }
    }
  }
}
