{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sjinks/ai-plugins/code-explorer/shared/schemas/open_questions.schema.json",
  "title": "open_questions.json",
  "type": "object",
  "required": ["_meta", "data"],
  "properties": {
    "_meta": { "$ref": "common.schema.json#/$defs/artifactMeta" },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "area"],
        "properties": {
          "id": { "$ref": "common.schema.json#/$defs/stableId" },
          "question": { "type": "string" },
          "whyItMatters": { "type": "string" },
          "area": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "suggestedResolution": { "type": "string" },
          "status": { "$ref": "common.schema.json#/$defs/status" }
        }
      }
    }
  }
}
